rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset enforces a strict user-ownership model designed for a website builder platform. 
     * Access control is primarily path-based, leveraging the hierarchical structure of the database 
     * to ensure users can only access and modify their own content.
     *
     * DATA STRUCTURE
     * - /users/{userId}: Private user profiles.
     * - /users/{userId}/websites/{websiteId}: Websites owned by a specific user.
     * - /users/{userId}/websites/{websiteId}/pages/{pageId}: Pages belonging to a specific website.
     * - /websiteThemes/{themeId}: Publicly readable pre-defined themes.
     * - /feedback/{feedbackId}: Publicly writable collection for user submissions.
     *
     * KEY SECURITY DECISIONS
     * 1. Authorization Independence: Ownership is derived directly from the document path 
     *    (e.g., /users/{userId}/...) or denormalized fields (e.g., feedback.userId). This avoids 
     *    expensive `get()` calls in rules.
     * 2. Prototyping Flexibility: Rules enforce WHO can write but do NOT enforce the exact 
     *    shape of the data (schema) to allow for rapid iteration.
     * 3. Relational Integrity: On creation, rules ensure that internal fields (like `userId` 
     *    or `websiteId`) match the path parameters to prevent data corruption.
     * 4. Secure Deletes: All updates and deletes require a check to ensure the document exists 
     *    before the operation proceeds.
     */

    // --- Global Helper Functions ---

    /** Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the authenticated user's UID matches the provided ID (usually from a path). */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Combined check for existence and ownership, used for updates and deletes. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for user profile documents. Restricted to the user themselves.
     * @path /users/{userId}
     * @allow (create) User 'abc' creates document /users/abc.
     * @deny (create) User 'abc' attempts to create document /users/xyz.
     * @principle Enforces path-based ownership for user profiles.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Rules for websites owned by a user.
       * @path /users/{userId}/websites/{websiteId}
       * @allow (list) User 'abc' fetches all documents under /users/abc/websites.
       * @deny (get) User 'abc' tries to get /users/def/websites/site1.
       * @principle Inherits ownership from the parent user path.
       */
      match /websites/{websiteId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);

        /**
         * @description Rules for pages within a specific website.
         * @path /users/{userId}/websites/{websiteId}/pages/{pageId}
         * @allow (update) User 'abc' updates page 'p1' in their own website 'w1'.
         * @deny (create) User 'abc' attempts to create a page in User 'def's website path.
         * @principle Deeply nested ownership verification via path parameters.
         */
        match /pages/{pageId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && request.resource.data.websiteId == websiteId;
          allow update: if isExistingOwner(userId) && request.resource.data.websiteId == resource.data.websiteId;
          allow delete: if isExistingOwner(userId);
        }
      }
    }

    /**
     * @description Rules for global website themes. Publicly readable, write-protected.
     * @path /websiteThemes/{themeId}
     * @allow (get) Any visitor (signed in or not) views a theme.
     * @deny (create) Any user attempts to upload a new theme to the global collection.
     * @principle Public read access for shared resources; admin-only writes (default denied).
     */
    match /websiteThemes/{themeId} {
      allow get, list: if true;
      allow create, update, delete: if false; // TODO: Add admin validation once admin roles are defined.
    }

    /**
     * @description Rules for feedback submissions. Users can submit; admins can read.
     * @path /feedback/{feedbackId}
     * @allow (create) An anonymous or signed-in user submits a feedback document.
     * @deny (get) A standard user attempts to read feedback submitted by others.
     * @principle "Drop-box" pattern: anyone can write, but reads are restricted.
     */
    match /feedback/{feedbackId} {
      allow get, list: if false; // Only administrators should read feedback.
      allow create: if true; // Public submission allowed as per requirements.
      allow update, delete: if false; // Feedback is immutable once sent.
    }
  }
}

/**
 * PROTOTYPING MODE NOTICE:
 * These rules prioritize authorization (who can access what) over data validation (schema).
 * General content fields are not type-checked to allow for rapid UI/UX iteration.
 * Immutability is enforced only on critical relational fields (ids and owners).
 */